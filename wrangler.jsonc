{
  "name": "my-cf-project",
  "main": "src/index.js",
  "compatibility_date": "2026-05-29",
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "my-images-db",
      "database_id": "e62dfb70-66d6-4352-9b1f-e65235264afa"
    }
  ],
  "r2_buckets": [
    {
      "binding": "MY_BUCKET",
      "bucket_name": "my-image-bucket"
    }
  ],
  "ai": {
    "binding": "AI"
  }
}